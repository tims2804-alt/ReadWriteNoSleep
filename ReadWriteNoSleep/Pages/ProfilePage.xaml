<Page x:Class="ReadWriteNoSleep.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Профиль"
      Background="#181825">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- ПРЕДУПРЕЖДЕНИЕ О ЗАМОРОЗКЕ -->
            <Border x:Name="PanelFrozen"
                    Background="#3d1a1a"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="🔒 Ваш аккаунт заморожен"
                               Foreground="#f38ba8"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtFrozenReason"
                               Foreground="#cdd6f4"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <Button Content="Оспорить заморозку"
                            Background="#f38ba8" Foreground="#1e1e2e"
                            BorderThickness="0" Padding="16,8"
                            FontWeight="Bold"
                            HorizontalAlignment="Left"
                            Click="BtnAppealFreeze_Click"/>
                </StackPanel>
            </Border>

            <!-- ИНФОРМАЦИЯ О ПОЛЬЗОВАТЕЛЕ -->
            <Border Background="#313244"
                    CornerRadius="8"
                    Padding="20"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Background="#45475a"
                            CornerRadius="40"
                            Width="80" Height="80"
                            Margin="0,0,20,0">
                        <TextBlock Text="👤" FontSize="36"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtDisplayName"
                                   Foreground="White"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtLogin"
                                   Foreground="#6c7086"
                                   FontSize="13"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="TxtEmail"
                                   Foreground="#6c7086"
                                   FontSize="13"
                                   Margin="0,0,0,8"/>
                        <Border Background="#45475a"
                                CornerRadius="4"
                                Padding="8,4"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="TxtRole"
                                       Foreground="#cba6f7"
                                       FontSize="12"
                                       FontWeight="Bold"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- КНОПКА ВЫХОДА -->
            <Button Content="🚪 Выйти из аккаунта"
                    Background="#f38ba8" Foreground="#1e1e2e"
                    BorderThickness="0" Padding="16,8"
                    FontWeight="Bold"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,20"
                    Click="BtnLogout_Click"/>

            <!-- ЗАЯВКА НА РОЛЬ АВТОРА -->
            <Border x:Name="PanelAuthorRequest"
                    Background="#313244"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,20"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="✍️ Стать автором"
                               Foreground="White"
                               FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Подайте заявку чтобы публиковать свои книги на платформе."
                               Foreground="#6c7086"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>
                    <Button x:Name="BtnRequestAuthor"
                            Content="Подать заявку"
                            Background="#cba6f7" Foreground="#1e1e2e"
                            BorderThickness="0" Padding="16,8"
                            FontWeight="Bold"
                            HorizontalAlignment="Left"
                            Click="BtnRequestAuthor_Click"/>
                </StackPanel>
            </Border>

            <!-- ОТЗЫВЫ ПОЛЬЗОВАТЕЛЯ -->
            <TextBlock Text="Мои отзывы"
                       Foreground="White"
                       FontSize="18" FontWeight="Bold"
                       Margin="0,0,0,12"/>

            <TextBlock x:Name="TxtNoReviews"
                       Text="Вы ещё не оставляли отзывов"
                       Foreground="#6c7086"
                       FontSize="14"
                       Margin="0,0,0,8"
                       Visibility="Collapsed"/>

            <ItemsControl x:Name="ReviewsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244"
                                CornerRadius="8"
                                Padding="16"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Book.Title}"
                                               Foreground="#cba6f7"
                                               FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Rating, StringFormat='⭐ {0}/10'}"
                                               Foreground="#f9e2af"/>
                                </Grid>
                                <TextBlock Text="{Binding ReviewText}"
                                           Foreground="#cdd6f4"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy}'}"
                                           Foreground="#6c7086"
                                           FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>