<Page x:Class="ReadWriteNoSleep.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог книг"
      Background="#181825">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ПАНЕЛЬ ФИЛЬТРОВ -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Строка 1: поиск + сортировка -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="200"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="TxtSearch"
                         Grid.Column="0"
                         Background="#313244"
                         BorderThickness="0" Padding="10,8"
                         Height="36" Margin="0,0,8,0"
                         Text="Поиск по названию или автору..."
                         Foreground="#6c7086"
                         GotFocus="TxtSearch_GotFocus"
                         LostFocus="TxtSearch_LostFocus"
                         TextChanged="TxtSearch_TextChanged"/>

                <Grid Grid.Column="1">
                    <ToggleButton x:Name="SortToggle"
                                  Height="36"
                                  Background="#313244"
                                  Foreground="White"
                                  BorderThickness="0"
                                  Padding="10,0"
                                  HorizontalContentAlignment="Left">
                        <Grid Width="170">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="20"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="TxtSortSelected"
                                       Grid.Column="0"
                                       Text="По названию (А-Я)"
                                       Foreground="White"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="▾"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                    </ToggleButton>
                    <Popup x:Name="SortPopup"
                           PlacementTarget="{Binding ElementName=SortToggle}"
                           Placement="Bottom"
                           IsOpen="{Binding IsChecked, ElementName=SortToggle}"
                           AllowsTransparency="True"
                           StaysOpen="False">
                        <Border Background="#313244" MinWidth="200">
                            <StackPanel>
                                <Button Content="По названию (А-Я)"
                                        Background="#313244" Foreground="White"
                                        BorderThickness="0" Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Tag="0" Click="SortOption_Click"/>
                                <Button Content="По названию (Я-А)"
                                        Background="#313244" Foreground="White"
                                        BorderThickness="0" Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Tag="1" Click="SortOption_Click"/>
                                <Button Content="По оценке (выше)"
                                        Background="#313244" Foreground="White"
                                        BorderThickness="0" Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Tag="2" Click="SortOption_Click"/>
                                <Button Content="По оценке (ниже)"
                                        Background="#313244" Foreground="White"
                                        BorderThickness="0" Padding="10,8"
                                        HorizontalContentAlignment="Left"
                                        Tag="3" Click="SortOption_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <!-- Строка 2: фильтр по жанрам -->
            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          Height="40">
                <StackPanel x:Name="PanelGenres" Orientation="Horizontal"/>
            </ScrollViewer>
        </Grid>

        <!-- СЕТКА КНИГ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BooksGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#313244"
                                CornerRadius="8"
                                Width="180" Height="280"
                                Margin="8" Cursor="Hand">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="160"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Обложка -->
                                <Border Grid.Row="0"
                                        CornerRadius="8,8,0,0"
                                        Background="#45475a"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image Stretch="Uniform"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Style>
                                                <Style TargetType="Image">
                                                    <Setter Property="Source" Value="{Binding CoverPath}"/>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Image.Style>
                                        </Image>
                                        <StackPanel HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding CoverPath}" Value="{x:Null}">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding CoverPath}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>
                                            <TextBlock Text="📖" FontSize="48"
                                                       HorizontalAlignment="Center"/>
                                            <TextBlock Text="Нет обложки"
                                                       Foreground="#6c7086" FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Название -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding Title}"
                                           Foreground="White"
                                           FontWeight="Bold"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           MaxHeight="40"
                                           Margin="8,8,8,2"/>

                                <!-- Автор + рейтинг -->
                                <Grid Grid.Row="2" Margin="8,0,8,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Author.DisplayName}"
                                               Foreground="#6c7086"
                                               FontSize="11"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding AvgRating}"
                                               Foreground="#f9e2af"
                                               FontSize="11"/>
                                </Grid>

                                <!-- Кнопки -->
                                <StackPanel Grid.Row="3"
                                            Orientation="Horizontal"
                                            Margin="6,0,6,8">
                                    <Button Content="Открыть"
                                            FontSize="11"
                                            Background="#cba6f7"
                                            Foreground="#1e1e2e"
                                            BorderThickness="0"
                                            Padding="8,5"
                                            Margin="0,0,6,0"
                                            FontWeight="Bold"
                                            Tag="{Binding BookId}"
                                            Click="BtnOpenBook_Click"/>
                                    <Button Content="+ Список"
                                            FontSize="11"
                                            Background="#45475a"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Padding="8,5"
                                            Tag="{Binding BookId}"
                                            Click="BtnAddToList_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>