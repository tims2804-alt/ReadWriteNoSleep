<!-- EditBookPage.xaml -->
<Page x:Class="ReadWriteNoSleep.Pages.EditBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Редактирование книги"
      Background="#181825">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Кнопка назад -->
            <Button Content="← Назад"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    Foreground="#cba6f7"
                    BorderThickness="0"
                    FontSize="14"
                    Margin="0,0,0,16"
                    Click="BtnBack_Click"/>

            <!-- Заголовок -->
            <TextBlock x:Name="TxtPageTitle"
                       Foreground="White"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,24"/>

            <!-- Название -->
            <TextBlock Text="Название книги"
                       Foreground="#cdd6f4" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtTitle"
                     Background="#313244" Foreground="White"
                     BorderThickness="0" Padding="10,8"
                     Height="36" Margin="0,0,0,16"/>

            <!-- Описание -->
            <TextBlock Text="Описание"
                       Foreground="#cdd6f4" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtDescription"
                     Background="#313244" Foreground="White"
                     BorderThickness="0" Padding="10"
                     Height="100" TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Margin="0,0,0,16"/>

            <!-- Жанры -->
            <TextBlock Text="Жанры"
                       Foreground="#cdd6f4" Margin="0,0,0,6"/>
            <Border Background="#313244"
                    CornerRadius="4"
                    Padding="8"
                    Margin="0,0,0,16">
                <WrapPanel x:Name="PanelGenres"/>
            </Border>

            <!-- Текст книги -->
            <TextBlock Text="Текст книги"
                       Foreground="#cdd6f4" Margin="0,0,0,6"/>
            <TextBox x:Name="TxtContent"
                     Background="#313244" Foreground="White"
                     BorderThickness="0" Padding="10"
                     Height="300" TextWrapping="Wrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,24"/>

            <!-- Кнопка сохранить -->
            <Button x:Name="BtnSave"
                    Content="💾 Сохранить"
                    Background="#cba6f7" Foreground="#1e1e2e"
                    BorderThickness="0" Padding="20,10"
                    FontWeight="Bold" FontSize="14"
                    HorizontalAlignment="Left"
                    Click="BtnSave_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>