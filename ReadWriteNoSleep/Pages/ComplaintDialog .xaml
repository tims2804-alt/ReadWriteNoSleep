<!-- ComplaintDialog.xaml -->
<Window x:Class="ReadWriteNoSleep.Pages.ComplaintDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подать жалобу" Height="280" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e2e">

    <StackPanel Margin="24">
        <TextBlock x:Name="TxtTarget"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <TextBlock Text="Причина жалобы"
                   Foreground="#cdd6f4" Margin="0,0,0,6"/>

        <TextBox x:Name="TxtReason"
                 Background="#313244" Foreground="White"
                 BorderThickness="0" Padding="10"
                 Height="100" TextWrapping="Wrap"
                 AcceptsReturn="True"
                 Margin="0,0,0,16"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Background="#313244" Foreground="White"
                    BorderThickness="0" Padding="16,8"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>

            <Button Content="Отправить жалобу"
                    Background="#f38ba8" Foreground="#1e1e2e"
                    BorderThickness="0" Padding="16,8"
                    FontWeight="Bold"
                    Click="BtnSubmit_Click"/>
        </StackPanel>
    </StackPanel>
</Window>