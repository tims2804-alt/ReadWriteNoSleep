<!-- ChangePasswordDialog.xaml -->
<Window x:Class="ReadWriteNoSleep.Pages.ChangePasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сменить пароль" Height="280" Width="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#1e1e2e">

    <StackPanel Margin="24">
        <TextBlock Text="Смена пароля"
                   Foreground="White" FontSize="16" FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock x:Name="TxtUserName"
                   Foreground="#6c7086" FontSize="12"
                   Margin="0,0,0,20"/>

        <TextBlock Text="Новый пароль"
                   Foreground="#cdd6f4" Margin="0,0,0,6"/>
        <PasswordBox x:Name="TxtNewPassword"
                     Background="#313244" Foreground="White"
                     BorderThickness="0" Padding="10,8"
                     Height="36" Margin="0,0,0,12"/>

        <TextBlock Text="Повторите пароль"
                   Foreground="#cdd6f4" Margin="0,0,0,6"/>
        <PasswordBox x:Name="TxtConfirmPassword"
                     Background="#313244" Foreground="White"
                     BorderThickness="0" Padding="10,8"
                     Height="36" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отмена"
                    Background="#313244" Foreground="White"
                    BorderThickness="0" Padding="16,8"
                    Margin="0,0,8,0"
                    Click="BtnCancel_Click"/>

            <Button Content="Сохранить"
                    Background="#cba6f7" Foreground="#1e1e2e"
                    BorderThickness="0" Padding="16,8"
                    FontWeight="Bold"
                    Click="BtnSave_Click"/>
        </StackPanel>
    </StackPanel>
</Window>