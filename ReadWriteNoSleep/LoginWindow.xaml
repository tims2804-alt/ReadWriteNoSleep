<Window x:Class="ReadWriteNoSleep.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" Height="560" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1e1e2e">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Center" Margin="40">

            <!-- Заголовок -->
            <TextBlock Text="Читай, Пиши и не спиши"
                       Foreground="White" FontSize="18" FontWeight="Bold"
                       TextAlignment="Center" Margin="0,20,0,24"/>

            <!-- Toggle кнопки -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnToggleLogin" Content="Вход"
                        Grid.Column="0"
                        Click="BtnToggleLogin_Click"
                        Background="#cba6f7" Foreground="#1e1e2e"
                        FontWeight="Bold" BorderThickness="0"
                        Height="40" FontSize="14"/>

                <Button x:Name="BtnToggleRegister" Content="Регистрация"
                        Grid.Column="1"
                        Click="BtnToggleRegister_Click"
                        Background="#313244" Foreground="#cdd6f4"
                        FontWeight="Bold" BorderThickness="0"
                        Height="40" FontSize="14"/>
            </Grid>

            <!-- Панель ВХОДА -->
            <StackPanel x:Name="PanelLogin">
                <TextBlock Text="Логин" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtLoginLogin"
                         Background="#313244" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Height="40" Margin="0,0,0,14" FontSize="14"/>

                <TextBlock Text="Пароль" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtLoginPassword"
                             Background="#313244" Foreground="White"
                             BorderThickness="0" Padding="10,8"
                             Height="40" Margin="0,0,0,24" FontSize="14"/>

                <Button Content="Войти"
                        Click="BtnLogin_Click"
                        Background="#cba6f7" Foreground="#1e1e2e"
                        FontWeight="Bold" BorderThickness="0"
                        Height="44" FontSize="15"/>
            </StackPanel>

            <!-- Панель РЕГИСТРАЦИИ -->
            <StackPanel x:Name="PanelRegister" Visibility="Collapsed">
                <TextBlock Text="Имя" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegDisplayName"
                         Background="#313244" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Height="40" Margin="0,0,0,14" FontSize="14"/>

                <TextBlock Text="Логин" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegLogin"
                         Background="#313244" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Height="40" Margin="0,0,0,14" FontSize="14"/>

                <TextBlock Text="Email" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <TextBox x:Name="TxtRegEmail"
                         Background="#313244" Foreground="White"
                         BorderThickness="0" Padding="10,8"
                         Height="40" Margin="0,0,0,14" FontSize="14"/>

                <TextBlock Text="Пароль" Foreground="#cdd6f4" Margin="0,0,0,4"/>
                <PasswordBox x:Name="TxtRegPassword"
                             Background="#313244" Foreground="White"
                             BorderThickness="0" Padding="10,8"
                             Height="40" Margin="0,0,0,24" FontSize="14"/>

                <Button Content="Зарегистрироваться"
                        Click="BtnRegister_Click"
                        Background="#cba6f7" Foreground="#1e1e2e"
                        FontWeight="Bold" BorderThickness="0"
                        Height="44" FontSize="15"/>
            </StackPanel>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="TxtError"
                       Foreground="#f38ba8"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,14,0,20"
                       Visibility="Collapsed"/>

        </StackPanel>
    </ScrollViewer>
</Window>