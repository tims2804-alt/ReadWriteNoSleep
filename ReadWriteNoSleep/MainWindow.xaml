<!-- MainWindow.xaml -->
<Window x:Class="ReadWriteNoSleep.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиши" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        MinHeight="500" MinWidth="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Grid Grid.Column="0" Background="#1e1e2e">
            <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">

                <!-- Каталог -->
                <Button x:Name="BtnCatalog"
                        Content="📚"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnCatalog_Click"
                        ToolTip="Каталог книг"
                        Margin="5,4"/>

                <!-- Списки книг -->
                <Button x:Name="BtnLists"
                        Content="📋"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnLists_Click"
                        ToolTip="Списки книг"
                        Margin="5,4"/>

                <!-- Страница автора (только для авторов) -->
                <Button x:Name="BtnAuthor"
                        Content="✍️"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnAuthor_Click"
                        ToolTip="Страница автора"
                        Margin="5,4"
                        Visibility="Collapsed"/>

                <!-- Администрирование (только для админа) -->
                <Button x:Name="BtnAdmin"
                        Content="🛡️"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnAdmin_Click"
                        ToolTip="Администрирование"
                        Margin="5,4"
                        Visibility="Collapsed"/>

                <!-- Предупреждение о заморозке (только если заморожен) -->
                <Button x:Name="BtnFrozen"
                        Content="🔒"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="#f38ba8"
                        Click="BtnFrozen_Click"
                        ToolTip="Аккаунт заморожен!"
                        Margin="5,4"
                        Visibility="Collapsed"/>

            </StackPanel>

            <!-- Профиль — прибит к низу -->
            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                <Button x:Name="BtnProfile"
                        Content="👤"
                        FontSize="22"
                        Height="50" Width="50"
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        Click="BtnProfile_Click"
                        ToolTip="Профиль"
                        Margin="5,4"/>
            </StackPanel>
        </Grid>

        <!-- ОСНОВНОЙ КОНТЕНТ -->
        <Frame Grid.Column="1"
               x:Name="MainFrame"
               NavigationUIVisibility="Hidden"
               Background="#181825"/>

    </Grid>
</Window>